.{
    .rules = .{
        .require_braces = .{
            .if_statement = .{ .warning = .multi_statement_only },
            .while_statement = .{ .@"error" = .multi_line_only },
            .for_statement = .{ .warning = .all },
            .catch_statement = .{ .warning = .all },
            .switch_case_statement = .{ .@"error" = .multi_line_only },
            .defer_statement = .{ .warning = .multi_statement_only },
            .errdefer_statement = .{ .warning = .all },
        },
    },
}
