.{
    .rules = .{
        // Default any rules overridden in the zlinters main package so that
        // integration tests run from the default + optional overrides.
        .field_naming = .{},
        .declaration_naming = .{},
        .function_naming = .{},
        .file_naming = .{},
        .import_ordering = .{},
        .no_unused = .{},
        .no_deprecated = .{},
        .no_empty_block = .{},
        .no_inferred_error_unions = .{},
        .no_orelse_unreachable = .{},
        .require_labeled_continue = .{},
        .no_unsafe_undefined = .{},
        .no_literal_only_bool_expression = .{},
        .no_hidden_allocations = .{},
        .switch_case_ordering = .{},
        .no_comment_out_code = .{},
        .no_todo = .{},
        .no_literal_args = .{},
        .no_swallow_error = .{},
        .no_panic = .{},
        .no_redundant_comptime = .{},
        .require_braces = .{},
        .require_doc_comment = .{},
        .field_ordering = .{},
        .max_positional_args = .{},
        .require_errdefer_dealloc = .{},
        .require_exhaustive_enum_switch = .{},
        .require_fmt = .{},
        .no_global_vars = .{},
    },
}
